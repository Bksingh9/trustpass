APP_NAME=TRUSTPASS API
ENVIRONMENT=local
API_V1_PREFIX=/api/v1
DATABASE_URL=postgresql+psycopg://trustpass:trustpass@postgres:5432/trustpass
REDIS_URL=redis://redis:6379/0
SUPABASE_PROJECT_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_JWT_AUDIENCE=authenticated
SUPABASE_JWT_ISSUER=
AUTH_MODE=auto
ALLOW_SYNTHETIC_PROOF_DATA=false
SEED_CONTEXT_TOKEN=
STORAGE_PROVIDER=local
LOCAL_STORAGE_ROOT=/data/uploads
S3_BUCKET=
S3_REGION=
S3_ENDPOINT_URL=
MAX_UPLOAD_BYTES=15728640
BILLING_PROVIDER=mock
BILLING_WEBHOOK_SECRET=
EMAIL_PROVIDER=mock
SENTRY_DSN=
LOG_LEVEL=INFO
ENABLE_DEMO_ROUTES=true
